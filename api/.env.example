# SMTP e destinatario form contatti
# Copiare in .env e compilare prima del deploy

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=tls
SMTP_FROM_EMAIL=noreply@touchlabs.it
SMTP_FROM_NAME=Touchlabs Sito Web
# SMTP_FROM_EMAIL deve usare un dominio @touchlabs.it (validato server-side)
CONTACT_TO_EMAIL=info@touchlabs.it
CONTACT_RATE_LIMIT_SECONDS=60
